{
  "name": "csv-entity-push-action",
  "version": "1.0.0",
  "description": "GitHub Action to detect CSV row changes and push SCIM SET events",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "test": "jest --coverage",
    "lint": "eslint src/ __tests__/",
    "all": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "sgnl",
    "csv",
    "scim",
    "entity-push",
    "github-action"
  ],
  "author": "SGNL Engineering",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/io": "^1.1.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}
